// Quality Dashboard — 공통 스키마 (QD·TRA 공유)
// User, Feedback, FeedbackReply 및 공통 enum 정의

generator client {
  provider = "prisma-client"
  output   = "../../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  passwordHash    String
  role            Role
  status          UserStatus @default(PENDING)
  statusReason    String?
  restrictedUntil DateTime?
  department      String?
  employeeId      String?
  phone           String?
  nickname        String?
  createdAt       DateTime   @default(now())

  feedbacks       Feedback[]
  feedbackReplies FeedbackReply[]
  boardPosts      BoardPost[]
  boardComments   BoardComment[]

  // TRA 관계 (tra.prisma 모델 추가 시 활성화)
  tenders         Tender[]
  reviewActions   ReviewHistory[]
  comments        Comment[]
}

model Feedback {
  id        String          @id @default(cuid())
  author    User            @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  imageUrls String?
  createdAt DateTime        @default(now())

  replies   FeedbackReply[]
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedback   Feedback @relation(fields: [feedbackId], references: [id])
  feedbackId String
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
  content    String
  createdAt  DateTime @default(now())
}

enum Role {
  PRACTITIONER // 실무자
  TEAM_LEAD    // 팀장
  DIRECTOR     // 부문장/임원
  ADMIN        // 시스템 관리자
}

enum UserStatus {
  PENDING
  ACTIVE
  RESTRICTED
  BANNED
}

// ─── 품질부문 게시판 ────────────────────────────────────────

enum BoardCategory {
  NOTICE  // 공지
  GENERAL // 일반
}

model BoardPost {
  id          String        @id @default(cuid())
  category    BoardCategory @default(GENERAL)
  pinned      Boolean       @default(false)
  title       String
  content     String
  author      User          @relation(fields: [authorId], references: [id])
  authorId    String
  displayMode String        @default("REAL") // REAL | NICKNAME | ANONYMOUS
  attachments Json          @default("[]")   // [{url,name,size,contentType}]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  comments    BoardComment[]
}

model BoardComment {
  id          String        @id @default(cuid())
  post        BoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  author      User          @relation(fields: [authorId], references: [id])
  authorId    String
  content     String
  displayMode String        @default("REAL") // REAL | NICKNAME | ANONYMOUS
  parentId    String?
  parent      BoardComment? @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     BoardComment[] @relation("Replies")
  createdAt   DateTime      @default(now())
}
