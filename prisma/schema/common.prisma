// Quality Dashboard — 공통 스키마 (QD·TRA 공유)
// User, Feedback, FeedbackReply 및 공통 enum 정의

generator client {
  provider = "prisma-client"
  output   = "../../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  passwordHash    String
  role            Role
  status          UserStatus @default(PENDING)
  statusReason    String?
  restrictedUntil DateTime?
  department      String?
  employeeId      String?
  phone           String?
  nickname        String?
  createdAt       DateTime   @default(now())

  feedbacks       Feedback[]
  feedbackReplies FeedbackReply[]
  boardPosts      BoardPost[]
  boardComments   BoardComment[]

  // TRA 관계
  tenders         Tender[]
  reviewActions   ReviewHistory[]
  comments        Comment[]

  // 수주 프로젝트 관계
  awardedProjects       AwardedProject[]        @relation("AwardedProjectCreator")
  contractReviewActions ContractReviewHistory[] @relation("ContractReviewHistoryUser")
  contractComments      ContractComment[]       @relation("ContractCommentAuthor")

  // 시설 자산 관계
  ownedEquipment  Equipment[]             @relation("EquipmentOwner")
  ownerHistoryAsOwner    EquipmentOwnerHistory[] @relation("OwnerHistoryOwner")
  ownerHistoryAsChanger  EquipmentOwnerHistory[] @relation("OwnerHistoryChangedBy")

  // 시험 계획 담당자 관계
  ownedTestPlans          TestPlan[]              @relation("TestPlanOwner")
  testPlanOwnerHistoryAsOwner    TestPlanOwnerHistory[]  @relation("TestPlanOwnerHistoryOwner")
  testPlanOwnerHistoryAsChanger  TestPlanOwnerHistory[]  @relation("TestPlanOwnerHistoryChangedBy")

  // 수선 이력
  reportedRepairs         EquipmentRepair[]       @relation("RepairReportedBy")

  // Q-Cost (클레임·NCR)
  claims                  Claim[]                 @relation("ClaimCreator")
  ncrs                    Ncr[]                   @relation("NcrCreator")

  // 공급망 관리
  supplierAudits          SupplierAudit[]         @relation("SupplierAuditCreator")
  incomingInspections     IncomingInspection[]    @relation("IncomingInspectionCreator")
  sourceInspections       SourceInspection[]      @relation("SourceInspectionCreator")

  // 사내 규격 관리
  internalStandards       InternalStandard[]      @relation("InternalStandardUploader")

  // QPA 공정감사
  qpaAudits               QpaAudit[]              @relation("QpaAuditCreator")

  // 회의록
  meetings                Meeting[]               @relation("MeetingCreator")

  // 협력업체 직접 등록
  vendorsCreated          Vendor[]                @relation("VendorCreator")
}

model Feedback {
  id        String          @id @default(cuid())
  author    User            @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  imageUrls String?
  createdAt DateTime        @default(now())

  replies   FeedbackReply[]
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedback   Feedback @relation(fields: [feedbackId], references: [id])
  feedbackId String
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
  content    String
  parentId   String?
  createdAt  DateTime @default(now())
}

enum Role {
  PRACTITIONER // 실무자
  TEAM_LEAD    // 팀장
  DIRECTOR     // 부문장/임원
  ADMIN        // 시스템 관리자
}

enum UserStatus {
  PENDING
  ACTIVE
  RESTRICTED
  BANNED
}

// ─── 품질부문 게시판 ────────────────────────────────────────

enum BoardCategory {
  NOTICE  // 공지
  GENERAL // 일반
}

model BoardPost {
  id          String        @id @default(cuid())
  category    BoardCategory @default(GENERAL)
  pinned      Boolean       @default(false)
  title       String
  content     String
  author      User          @relation(fields: [authorId], references: [id])
  authorId    String
  displayMode String        @default("REAL") // REAL | NICKNAME | ANONYMOUS
  visibility  String        @default("ALL")  // ALL | TEAM_LEAD_UP | DIRECTOR_UP
  attachments Json          @default("[]")   // [{url,name,size,contentType}]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  comments    BoardComment[]
}

// ─── 회의록 ─────────────────────────────────────────────────

enum MeetingType {
  QUALITY_ISSUE       // 품질이슈 회의
  STANDARD_REVIEW     // 표준검토 회의
  CHANGE_MANAGEMENT   // 변경관리 회의
  QUALITY_MEETING     // 품질회의
  OTHER               // 기타
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  type        MeetingType
  meetingDate DateTime
  body        String        @default("")   // 회의록 본문 (마크다운)
  issueLinks  Json          @default("[]") // [{issueType, issueId, issueLabel}]
  createdBy   User          @relation("MeetingCreator", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  actions     MeetingAction[]
}

model MeetingAction {
  id           String    @id @default(cuid())
  meeting      Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId    String
  content      String
  assigneeName String
  dueDate      DateTime?
  done         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BoardComment {
  id          String        @id @default(cuid())
  post        BoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  author      User          @relation(fields: [authorId], references: [id])
  authorId    String
  content     String
  displayMode String        @default("REAL") // REAL | NICKNAME | ANONYMOUS
  visibility  String        @default("ALL")  // ALL | TEAM_LEAD_UP | DIRECTOR_UP
  parentId    String?
  parent      BoardComment? @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     BoardComment[] @relation("Replies")
  createdAt   DateTime      @default(now())
}
